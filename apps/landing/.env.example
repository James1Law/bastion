# Resend — required for the /api/waitlist edge function.
# Get the API key from https://resend.com/api-keys (server-side, never expose in client code).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# The audience that signups are added to.
# In the Resend dashboard, go to Audiences → your audience → copy the ID.
# (The SDK calls this a "segment" internally; it's the same thing.)
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000

# Sender for the confirmation email. Must be on a domain you've verified in Resend.
# For Resend's sandbox you can use onboarding@resend.dev while testing.
WAITLIST_FROM_EMAIL=hello@yourdomain.com

# Optional. If set, every waitlist submission is also emailed here with the
# full payload (name, email, role, "what are you building"). Without this,
# the optional fields are accepted by the form but never stored anywhere.
WAITLIST_NOTIFY_EMAIL=you@yourdomain.com
